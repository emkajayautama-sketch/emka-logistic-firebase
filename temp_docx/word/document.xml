4" w:color="1B365D"/></w:pBdr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b/><w:i w:val="0"/><w:color w:val="1B365D"/><w:sz w:val="32"/></w:rPr><w:t>I. PENDAHULUAN DAN TUJUAN SISTEM</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:line="276" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Sistem Informasi Logistik Pelabuhan Terpadu (SILOP) dirancang khusus untuk mengakomodasi kebutuhan operasional perusahaan Jasa Perusahaan Bongkar Muat (PBM) dan Jasa Pengurusan Transportasi (JPT). Sistem ini bersifat umum, mengelola tidak hanya komoditas peti kemas (kontainer), melainkan komoditas non-kontainer seperti barang curah kering (pasir besi, batu, semen), curah cair (BBM, aspal), dan general cargo (besi beton, tiang pancang).</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:line="276" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Tujuan utama sistem ini adalah mengintegrasikan sirkulasi dokumen administrasi, pencatatan eksekusi fisik dilapangan secara real-time melaui sistem Tally Digital, otomatisasi rekapitulasi laporan regulasi bulanan/tahunan untuk KSOP, serta penyediaan jalur akses cepat (shortcut link) ke portal eksternal seperti Inaportnet tanpa terjadi kendala double-input.</w:t></w:r></w:p><w:p><w:pPr><w:keepNext/><w:spacing w:before="360" w:after="120"/><w:pBdr><w:bottom w:val="single" w:sz="6" w:space="4" w:color="1B365D"/></w:pBdr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b/><w:i w:val="0"/><w:color w:val="1B365D"/><w:sz w:val="32"/></w:rPr><w:t>II. ARSITEKTUR STRUKTUR MENU APLIKASI</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:line="276" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w