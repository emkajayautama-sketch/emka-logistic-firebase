sz="4" w:space="0" w:color="D1D5DB"/><w:bottom w:val="single" w:sz="4" w:space="0" w:color="D1D5DB"/><w:left w:val="none"/><w:right w:val="none"/></w:tcBorders><w:shd w:fill="F4F6F8"/></w:tcPr><w:p><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b/><w:i w:val="0"/><w:color w:val="1B365D"/><w:sz w:val="20"/></w:rPr><w:t>8.2. Master Data Logistik</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3120"/><w:tcMar><w:top w:w="120" w:type="dxa"/><w:bottom w:w="120" w:type="dxa"/><w:left w:w="180" w:type="dxa"/><w:right w:w="180" w:type="dxa"/></w:tcMar><w:vAlign w:val="center"/><w:tcBorders><w:top w:val="single" w:sz="4" w:space="0" w:color="D1D5DB"/><w:bottom w:val="single" w:sz="4" w:space="0" w:color="D1D5DB"/><w:left w:val="none"/><w:right w:val="none"/></w:tcBorders><w:shd w:fill="F4F6F8"/></w:tcPr><w:p><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="20"/></w:rPr><w:t>8.2.1. Database Kapal &amp; Agen Pelayaran</w:t><w:br/><w:t>8.2.2. Database Klien / Pemilik Barang</w:t><w:br/><w:t>8.2.3. Tabel Tarif Jasa &amp; Komponen Pajak (PPN)</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:keepNext/><w:spacing w:before="360" w:after="120"/><w:pBdr><w:bottom w:val="single" w:sz="6" w:space="4" w:color="1B365D"/></w:pBdr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b/><w:i w:val="0"/><w:color w:val="1B365D"/><w:sz w:val="32"/></w:rPr><w:t>III. WORKFLOW ALUR KERJA SISTEM (END-TO-END)</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:line="276" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Alur sirkulasi data dan aktivitas pengguna di dalam sistem diatur mengikuti kronologi pergerakan kapal dan pengurusan barang sebagai berikut:</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="60"/><w:ind w:left="360"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Tahap Pra-Kedatangan: Klien memesan jasa logistik. Staf Admin JPT menginput data kapal dan muatan di Menu 2. Sistem secara otomatis menyediakan format teks ringkas untuk memudahkan admin melakukan copy-paste data ke portal resmi Inaportnet melalui menu jalan pintas (Menu 5).</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="60"/><w:ind w:left="360"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Tahap Perencanaan Lapangan: Staf Admin PBM menyusun Rencana Bongkar Muat (RBM) serta menetapkan alokasi kelompok kerja (Geng TKBM) dan alat berat pendukung di Menu 3.1.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="60"/><w:ind w:left="360"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Tahap Eksekusi Lapangan: Kapal sandar. Petugas Tally Lapangan melakukan pencatatan real-time hasil bongkar/muat menggunakan tablet/handphone pada Menu 3.2. Setiap truk pengangkut komoditas dibekali Surat Jalan Digital ber-QR Code.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="60"/><w:ind w:left="360"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Tahap Validasi Gerbang: Truk melewati jembatan timbang menuju pintu keluar pelabuhan. Petugas gate memindai QR Code menggunakan Menu 4. Sistem secara otomatis menarik angka berat bersih barang (netto) dari jembatan timbang dan menguncinya ke database.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListBullet"/><w:spacing w:after="60"/><w:ind w:left="360"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Tahap Finalisasi &amp; Pelaporan: Selesai operasional, sistem secara otomatis mengunci angka aktual ke dalam dokumen Outturn Report, menerbitkan draf Invoice Tagihan di Menu 7, serta menyusun berkas Laporan Bulanan KSOP di Menu 6.</w:t></w:r></w:p><w:p><w:pPr><w:keepNext/><w:spacing w:before="360" w:after="120"/><w:pBdr><w:bottom w:val="single" w:sz="6" w:space="4" w:color="1B365D"/></w:pBdr></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b/><w:i w:val="0"/><w:color w:val="1B365D"/><w:sz w:val="32"/></w:rPr><w:t>IV. CATATAN TEKNIS DAN PENGEMBANGAN (DEVELOPMENT NOTES)</w:t></w:r></w:p><w:p><w:pPr><w:keepNext/><w:spacing w:before="240" w:after="80"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b/><w:i w:val="0"/><w:color w:val="4A777A"/><w:sz w:val="26"/></w:rPr><w:t>1. Desain UI Khusus Lapangan (Mobile Responsive)</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:line="276" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Modul Tally Lapangan (Menu 3.2) dan Scanner Portal (Menu 4) wajib dikembangkan dengan prinsip mobile-first. Tampilan antarmuka harus menggunakan tombol berukuran besar, skema warna kontras tinggi agar tetap terlihat jelas di bawah terik matahari dermaga, serta pemrosesan data yang ringan.</w:t></w:r></w:p><w:tbl><w:tblPr><w:tblW w:type="auto" w:w="0"/><w:jc w:val="center"/><w:tblLook w:firstColumn="1" w:firstRow="1" w:lastColumn="0" w:lastRow="0" w:noHBand="0" w:noVBand="1" w:val="04A0"/></w:tblPr><w:tblGrid><w:gridCol w:w="9360"/></w:tblGrid><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="9360"/><w:tcMar><w:top w:w="140" w:type="dxa"/><w:bottom w:w="140" w:type="dxa"/><w:left w:w="200" w:type="dxa"/><w:right w:w="200" w:type="dxa"/></w:tcMar><w:tcBorders><w:top w:val="none"/><w:bottom w:val="none"/><w:left w:val="single" w:sz="24" w:space="0" w:color="1B365D"/><w:right w:val="none"/></w:tcBorders><w:shd w:fill="F4F6F8"/></w:tcPr><w:p><w:pPr><w:spacing w:after="0" w:line="276" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i/><w:color w:val="1B365D"/><w:sz w:val="21"/></w:rPr><w:t>Rekomendasi Keamanan Sistem (Role Permissions):</w:t><w:br/><w:t>Hak akses sistem wajib dibatasi ketat menggunakan User Roles (Menu 8.1). Petugas Tally Lapangan hanya diberikan hak akses menulis pada modul input harian dan dilarang keras melihat data keuangan (Menu 7) ataupun menu konfigurasi master.</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:spacing w:after="240"/></w:pPr></w:p><w:p><w:pPr><w:keepNext/><w:spacing w:before="240" w:after="80"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b/><w:i w:val="0"/><w:color w:val="4A777A"/><w:sz w:val="26"/></w:rPr><w:t>2. Integrasi Tautan Inaportnet (Webview Shortcuts)</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:line="276" w:lineRule="auto"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial"/><w:b w:val="0"/><w:i w:val="0"/><w:color w:val="333333"/><w:sz w:val="22"/></w:rPr><w:t>Mengingat kebijakan keamanan siber server kementerian menutup akses API langsung dari sistem swasta, integrasi dilakukan menggunakan tautan langsung (Deep Linking) yang tertanam di dalam aplikasi. Untuk mempercepat proses administrasi, sistem internal wajib menyediakan fitur Teks Generator Otomatis yang mengompilasi manifest menjadi draf siap salin (copy), sehingga meminimalkan kesalahan pengetikan ulang (human error) oleh staf administrasi.</w:t></w:r></w:p><w:sectPr w:rsidR="00FC693F" w:rsidRPr="0006063C" w:rsidSect="00034616"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="720" w:footer="720" w:gutter="0"/><w:cols w:space="720"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>